@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceArrowColor #A389D4
skinparam sequenceArrowFontColor #000000
skinparam sequenceArrowFontSize 11
skinparam participant {
  BackgroundColor #F0EBFF
  BorderColor #C4ADEE
  FontColor #3D2478
  FontSize 12
  FontStyle bold
}
skinparam database {
  BackgroundColor #F0EBFF
  BorderColor #C4ADEE
  FontColor #3D2478
  FontSize 12
  FontStyle bold
}
skinparam actor {
  BackgroundColor #E8DFFF
  BorderColor #A389D4
  FontColor #3D2478
  FontSize 13
  FontStyle bold
}
skinparam sequence {
  LifeLineBorderColor #C4ADEE
  LifeLineBackgroundColor #FFFFFF
  GroupBackgroundColor #FFFFFF
  GroupBorderColor #A389D4
  GroupFontColor #000000
  GroupHeaderFontColor #A389D4
  DividerBackgroundColor #FFFFFF
  DividerBorderColor #000000
  DividerFontColor #000000
  BoxBackgroundColor #FFFFFF
  BoxBorderColor #A389D4
  ActivationBorderColor #7F77DD
  ActivationBackgroundColor #E8DFFF
}
skinparam shadowing false
skinparam roundcorner 12
skinparam noteBorderColor #C4ADEE
skinparam noteBackgroundColor #F0EBFF
skinparam noteFontColor #3D2478

title UC06 — Visualizar Estante Literária

actor Leitor
participant "App\n(Mobile)" as App
participant "Backend\n(API)" as API
participant "EstanteController" as Controller
participant "VisualizarEstanteService" as Service
participant "EstanteRepository" as EstanteRepo
participant "LivroRepository" as LivroRepo
database "PostgreSQL" as DB

== Carregar estante completa ==

Leitor -> App : Acessa seção "Minha Estante"
activate App

App -> API : GET /shelf/{usuario_id}
activate API

API -> Controller : visualizarEstante(usuarioId, status=null)
activate Controller

Controller -> Service : buscarEstanteCompleta(usuarioId)
activate Service

Service -> EstanteRepo : findByUsuarioId(usuarioId)
activate EstanteRepo

EstanteRepo -> DB : SELECT estante WHERE usuario_id = ?
activate DB
DB --> EstanteRepo : Retorna registro da estante
deactivate DB

EstanteRepo --> Service : Retorna Estante com EstanteItens
deactivate EstanteRepo

Service -> LivroRepo : findById(livroId) [para cada item]
activate LivroRepo

LivroRepo -> DB : SELECT livro WHERE id IN (livro_ids)
activate DB
DB --> LivroRepo : Retorna dados dos livros
deactivate DB

LivroRepo --> Service : Retorna lista de Livros
deactivate LivroRepo

Service -> Service : mapearEstante(estante)

Service --> Controller : Retorna Estante populada
deactivate Service

Controller --> API : ResponseEntity<Estante>
deactivate Controller

API --> App : Retorna estante completa com livros
deactivate API

== Visualizar resumo da estante ==

Leitor -> App : Acessa resumo / estatísticas da estante
activate App

App -> API : GET /shelf/{usuario_id}/summary
activate API

API -> Controller : resumoEstante(usuarioId)
activate Controller

Controller -> Service : buscarResumoEstante(usuarioId)
activate Service

Service -> EstanteRepo : findByUsuarioId(usuarioId)
activate EstanteRepo

EstanteRepo -> DB : SELECT estante + COUNT por status
activate DB
DB --> EstanteRepo : Retorna estante com contagens
deactivate DB

EstanteRepo --> Service : Retorna Estante
deactivate EstanteRepo

Service -> Service : getTotalLivros()\ngetItensPorStatus(cada status)

Service --> Controller : Retorna resumo da Estante
deactivate Service

Controller --> API : ResponseEntity<Estante>
deactivate Controller

API --> App : Retorna totais por status e geral
deactivate API

App --> Leitor : Exibe painel de resumo\n(Lendo, Lidos, Quero Ler, Abandonados)
deactivate App

@enduml
