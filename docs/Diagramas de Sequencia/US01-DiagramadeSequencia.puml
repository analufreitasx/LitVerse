@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceArrowColor #A389D4
skinparam sequenceArrowFontColor #000000
skinparam sequenceArrowFontSize 11
skinparam participant {
  BackgroundColor #F0EBFF
  BorderColor #C4ADEE
  FontColor #3D2478
  FontSize 12
  FontStyle bold
}
skinparam database {
  BackgroundColor #F0EBFF
  BorderColor #C4ADEE
  FontColor #3D2478
  FontSize 12
  FontStyle bold
}
skinparam actor {
  BackgroundColor #E8DFFF
  BorderColor #A389D4
  FontColor #3D2478
  FontSize 13
  FontStyle bold
}
skinparam sequence {
  LifeLineBorderColor #C4ADEE
  LifeLineBackgroundColor #FFFFFF
  GroupBackgroundColor #FFFFFF
  GroupBorderColor #A389D4
  GroupFontColor #000000
  GroupHeaderFontColor #A389D4
  DividerBackgroundColor #FFFFFF
  DividerBorderColor #000000
  DividerFontColor #000000
  BoxBackgroundColor #FFFFFF
  BoxBorderColor #A389D4
  ActivationBorderColor #7F77DD
  ActivationBackgroundColor #E8DFFF
}
skinparam shadowing false
skinparam roundcorner 12
skinparam noteBorderColor #C4ADEE
skinparam noteBackgroundColor #F0EBFF
skinparam noteFontColor #3D2478

title US01 — Adicionar livro à estante literária

actor Leitor
participant "App\n(Mobile)" as App
participant "Backend\n(API)" as API
database "PostgreSQL" as DB

== Adicionar livro à estante ==

Leitor -> App : Busca livro por título ou ISBN
activate App

App -> API : GET /books?query={termo}
activate API

API -> DB : Consulta catálogo
activate DB
DB --> API : Retorna lista de livros
deactivate DB

API --> App : Exibe resultados
deactivate API

alt [livro encontrado]
  Leitor -> App : Seleciona o livro desejado

  App -> API : POST /shelf {livro_id, usuario_id}
  activate API

  API -> DB : Insere livro com status "Quero Ler"
  activate DB
  DB --> API : Confirma inserção
  deactivate DB

  API --> App : Retorna livro adicionado
  deactivate API

  App --> Leitor : Exibe livro na estante
  deactivate App

else [livro não encontrado]
  App --> Leitor : Exibe mensagem "Nenhum resultado encontrado"
  deactivate App

end
@enduml