@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceArrowColor #A389D4
skinparam sequenceArrowFontColor #000000
skinparam sequenceArrowFontSize 11
skinparam participant {
  BackgroundColor #F0EBFF
  BorderColor #C4ADEE
  FontColor #3D2478
  FontSize 12
  FontStyle bold
}
skinparam database {
  BackgroundColor #F0EBFF
  BorderColor #C4ADEE
  FontColor #3D2478
  FontSize 12
  FontStyle bold
}
skinparam actor {
  BackgroundColor #E8DFFF
  BorderColor #A389D4
  FontColor #3D2478
  FontSize 13
  FontStyle bold
}
skinparam sequence {
  LifeLineBorderColor #C4ADEE
  LifeLineBackgroundColor #FFFFFF
  GroupBackgroundColor #FFFFFF
  GroupBorderColor #A389D4
  GroupFontColor #000000
  GroupHeaderFontColor #A389D4
  DividerBackgroundColor #FFFFFF
  DividerBorderColor #000000
  DividerFontColor #000000
  BoxBackgroundColor #FFFFFF
  BoxBorderColor #A389D4
  ActivationBorderColor #7F77DD
  ActivationBackgroundColor #E8DFFF
}
skinparam shadowing false
skinparam roundcorner 12
skinparam noteBorderColor #C4ADEE
skinparam noteBackgroundColor #F0EBFF
skinparam noteFontColor #3D2478

title UC04 — Escrever Resenha

actor Leitor
participant "App\n(Mobile)" as App
participant "ResenhaController" as Controller
participant "ResenhaService" as Service
participant "AvaliacaoRepository" as AvaliacaoRepo
participant "ResenhaRepository" as ResenhaRepo
database "PostgreSQL" as DB

== Criar resenha ==

Leitor -> App : Acessa livro na estante,\nvisualiza resenhas e seleciona "Escrever Resenha"
activate App

App -> Controller : GET /reviews?livroId={livro_id}
activate Controller

Controller -> Service : listarResenhasPublicas(livroId)
activate Service

Service -> ResenhaRepo : findPublicasByLivroId(livroId)
activate ResenhaRepo
ResenhaRepo -> DB : SELECT * FROM resenhas\nWHERE livro_id = ? AND publica = true
activate DB
DB --> ResenhaRepo : List<Resenha>
deactivate DB
ResenhaRepo --> Service : List<Resenha>
deactivate ResenhaRepo

Service --> Controller : List<Resenha>
deactivate Service
Controller --> App : 200 OK
deactivate Controller

App --> Leitor : Exibe resenhas existentes\ne formulário de nova resenha
deactivate App

Leitor -> App : Preenche título, corpo\ne visibilidade (pública/privada)
activate App

App -> Controller : POST /reviews\n{usuarioId, livroId, titulo, corpo, publica}
activate Controller

Controller -> Service : criarResenha(ResenhaDTO)
activate Service

note right of Service
  Verifica se o usuário possui
  avaliação registrada para o livro
  antes de permitir a resenha
end note

Service -> AvaliacaoRepo : findByUsuarioIdELivroId(usuarioId, livroId)
activate AvaliacaoRepo
AvaliacaoRepo -> DB : SELECT * FROM avaliacoes\nWHERE usuario_id = ? AND livro_id = ?
activate DB
DB --> AvaliacaoRepo : Avaliacao | null
deactivate DB
AvaliacaoRepo --> Service : Avaliacao | null
deactivate AvaliacaoRepo

alt [avaliação existente — resenha permitida]

  Service -> ResenhaRepo : save(Resenha)
  activate ResenhaRepo
  ResenhaRepo -> DB : INSERT INTO resenhas\n(id, avaliacao_id, usuario_id, livro_id,\ntitulo, corpo, publica, criado_em)
  activate DB
  DB --> ResenhaRepo : Confirma inserção
  deactivate DB
  ResenhaRepo --> Service : Resenha persistida
  deactivate ResenhaRepo

  Service --> Controller : Resenha criada
  deactivate Service
  Controller --> App : 201 Created
  deactivate Controller
  App --> Leitor : Exibe resenha publicada\nna página do livro
  deactivate App

else [sem avaliação — resenha bloqueada]

  Service --> Controller : Lança PreconditionFailedException
  deactivate Service
  Controller --> App : 422 Unprocessable Entity\n"Avalie o livro antes de escrever uma resenha"
  deactivate Controller
  App --> Leitor : Exibe alerta e redireciona\npara tela de avaliação
  deactivate App

end

== Gerenciar resenha ==

Leitor -> App : Seleciona resenha própria\ne escolhe "Editar" ou "Excluir"
activate App

alt [Editar]

  App -> Controller : PATCH /reviews/{resenhaId}\n{usuarioId, titulo, corpo, publica}
  activate Controller
  Controller -> Service : editarResenha(ResenhaDTO)
  activate Service

  note right of Service
    Valida se o usuário é
    proprietário da resenha
  end note

  Service -> ResenhaRepo : findByAvaliacaoId(avaliacaoId)
  activate ResenhaRepo
  ResenhaRepo -> DB : SELECT * FROM resenhas WHERE id = ?
  activate DB
  DB --> ResenhaRepo : Resenha
  deactivate DB
  ResenhaRepo --> Service : Resenha
  deactivate ResenhaRepo

  Service -> ResenhaRepo : update(Resenha)
  activate ResenhaRepo
  ResenhaRepo -> DB : UPDATE resenhas SET titulo = ?, corpo = ?,\npublica = ?, atualizado_em = NOW()\nWHERE id = ?
  activate DB
  DB --> ResenhaRepo : Confirma atualização
  deactivate DB
  ResenhaRepo --> Service : Resenha atualizada
  deactivate ResenhaRepo

  Service --> Controller : Resenha editada
  deactivate Service
  Controller --> App : 200 OK
  deactivate Controller
  App --> Leitor : Exibe resenha com alterações salvas
  deactivate App

else [Excluir]

  App -> Controller : DELETE /reviews/{resenhaId}\n{usuarioId}
  activate Controller
  Controller -> Service : excluirResenha(resenhaId, usuarioId)
  activate Service

  Service -> ResenhaRepo : findByAvaliacaoId(avaliacaoId)
  activate ResenhaRepo
  ResenhaRepo -> DB : SELECT * FROM resenhas WHERE id = ?
  activate DB
  DB --> ResenhaRepo : Resenha
  deactivate DB
  ResenhaRepo --> Service : Resenha
  deactivate ResenhaRepo

  Service -> ResenhaRepo : delete(resenhaId)
  activate ResenhaRepo
  ResenhaRepo -> DB : DELETE FROM resenhas WHERE id = ?
  activate DB
  DB --> ResenhaRepo : Confirma exclusão
  deactivate DB
  ResenhaRepo --> Service : void
  deactivate ResenhaRepo

  Service --> Controller : Exclusão confirmada
  deactivate Service
  Controller --> App : 204 No Content
  deactivate Controller
  App --> Leitor : Remove resenha da página do livro
  deactivate App

end

@enduml
