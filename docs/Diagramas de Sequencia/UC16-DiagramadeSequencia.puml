@startuml UC16_DiscutirCapitulosEmGrupo

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowColor #A389D4
skinparam sequenceArrowFontColor #000000
skinparam sequenceArrowFontSize 11
skinparam participant {
  BackgroundColor #F0EBFF
  BorderColor #C4ADEE
  FontColor #3D2478
  FontSize 12
  FontStyle bold
}
skinparam database {
  BackgroundColor #F0EBFF
  BorderColor #C4ADEE
  FontColor #3D2478
  FontSize 12
  FontStyle bold
}
skinparam actor {
  BackgroundColor #E8DFFF
  BorderColor #A389D4
  FontColor #3D2478
  FontSize 13
  FontStyle bold
}
skinparam sequence {
  LifeLineBorderColor #C4ADEE
  LifeLineBackgroundColor #FFFFFF
  GroupBackgroundColor #FFFFFF
  GroupBorderColor #A389D4
  GroupFontColor #000000
  GroupHeaderFontColor #A389D4
  DividerBackgroundColor #FFFFFF
  DividerBorderColor #000000
  DividerFontColor #000000
  BoxBackgroundColor #FFFFFF
  BoxBorderColor #A389D4
  ActivationBorderColor #7F77DD
  ActivationBackgroundColor #E8DFFF
}
skinparam shadowing false
skinparam roundcorner 12
skinparam noteBorderColor #C4ADEE
skinparam noteBackgroundColor #F0EBFF
skinparam noteFontColor #3D2478

title UC16 — Discutir Capítulos em Grupo

actor Leitor
participant "App\n(Mobile)" as App
participant "DiscussaoController" as DC
participant "DiscussaoService" as DS
participant "DiscussaoRepository" as DR
participant "ComentarioRepository" as CR
participant "MembroRepository" as MR
participant "NotificacaoService" as NS
database "PostgreSQL" as DB

== Criar Discussão de Capítulo ==

Leitor -> App : Acessa painel do clube\ne seleciona "Nova Discussão"
activate App

App -> DC : GET /clubes/{clubeId}/discussoes
activate DC

DC -> DS : listarDiscussoes(clubeId)
activate DS

DS -> DR : findByClubeId(clubeId)
activate DR
DR -> DB : SELECT discussoes WHERE clubeId = clubeId\nORDER BY fixada DESC, criadaEm DESC
activate DB
DB --> DR : List<Discussao>
deactivate DB
DR --> DS : List<Discussao>
deactivate DR

DS --> DC : List<Discussao>
deactivate DS

DC --> App : 200 OK {discussoes}
deactivate DC

App --> Leitor : Exibe lista de discussões do clube
deactivate App

Leitor -> App : Preenche título, corpo e\nnúmero do capítulo e confirma
activate App

App -> DC : POST /clubes/{clubeId}/discussoes\n{CriarDiscussaoDTO}
activate DC

DC -> DS : criarDiscussao(dto: CriarDiscussaoDTO)
activate DS

DS -> MR : existsByUsuarioIdEClubeId(usuarioId, clubeId)
activate MR
MR -> DB : SELECT EXISTS membro
activate DB
DB --> MR : Boolean
deactivate DB
MR --> DS : true
deactivate MR

note over DS : validarMembro:\nusuário deve ser membro ativo do clube

DS -> DR : save(discussao: Discussao\n{clubeId, autorId, titulo, corpo, capitulo})
activate DR
DR -> DB : INSERT INTO discussoes
activate DB
DB --> DR : Discussao persistida
deactivate DB
DR --> DS : Discussao
deactivate DR

DS -> NS : enviarNotificacao(membrosIds,\nNOVA_DISCUSSAO, payload)
activate NS
NS --> DS : ok
deactivate NS

DS --> DC : Discussao
deactivate DS

DC --> App : 201 Created {discussao}
deactivate DC

App --> Leitor : Exibe discussão criada
deactivate App

== Comentar em Discussão ==

Leitor -> App : Seleciona discussão e\ndigita comentário
activate App

App -> DC : POST /discussoes/{discussaoId}/comentarios\n{usuarioId, texto, respondeAId?}
activate DC

DC -> DS : adicionarComentario(discussaoId,\nusuarioId, texto, respondeAId)
activate DS

DS -> DR : findById(discussaoId)
activate DR
DR -> DB : SELECT discussao WHERE id = discussaoId
activate DB
DB --> DR : Discussao
deactivate DB
DR --> DS : Discussao
deactivate DR

DS -> MR : existsByUsuarioIdEClubeId(usuarioId, clubeId)
activate MR
MR -> DB : SELECT EXISTS membro
activate DB
DB --> MR : Boolean
deactivate DB
MR --> DS : true
deactivate MR

alt [respondeAId informado]
  note over DS : Comentário é uma resposta\na outro comentário existente
end

DS -> CR : save(comentario: Comentario\n{discussaoId, autorId, texto, respondeAId})
activate CR
CR -> DB : INSERT INTO comentarios
activate DB
DB --> CR : Comentario persistido
deactivate DB
CR --> DS : Comentario
deactivate CR

DS -> NS : enviarNotificacao(autorDiscussaoId,\nNOVO_COMENTARIO, payload)
activate NS
NS --> DS : ok
deactivate NS

DS --> DC : Comentario
deactivate DS

DC --> App : 201 Created {comentario}
deactivate DC

App --> Leitor : Exibe comentário na discussão
deactivate App

@enduml
