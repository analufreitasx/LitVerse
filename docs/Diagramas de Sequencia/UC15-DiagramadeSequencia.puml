@startuml UC15_ParticiparClubeDoLivro

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowColor #A389D4
skinparam sequenceArrowFontColor #000000
skinparam sequenceArrowFontSize 11
skinparam participant {
  BackgroundColor #F0EBFF
  BorderColor #C4ADEE
  FontColor #3D2478
  FontSize 12
  FontStyle bold
}
skinparam database {
  BackgroundColor #F0EBFF
  BorderColor #C4ADEE
  FontColor #3D2478
  FontSize 12
  FontStyle bold
}
skinparam actor {
  BackgroundColor #E8DFFF
  BorderColor #A389D4
  FontColor #3D2478
  FontSize 13
  FontStyle bold
}
skinparam sequence {
  LifeLineBorderColor #C4ADEE
  LifeLineBackgroundColor #FFFFFF
  GroupBackgroundColor #FFFFFF
  GroupBorderColor #A389D4
  GroupFontColor #000000
  GroupHeaderFontColor #A389D4
  DividerBackgroundColor #FFFFFF
  DividerBorderColor #000000
  DividerFontColor #000000
  BoxBackgroundColor #FFFFFF
  BoxBorderColor #A389D4
  ActivationBorderColor #7F77DD
  ActivationBackgroundColor #E8DFFF
}
skinparam shadowing false
skinparam roundcorner 12
skinparam noteBorderColor #C4ADEE
skinparam noteBackgroundColor #F0EBFF
skinparam noteFontColor #3D2478

title UC15 — Participar de Clube do Livro

actor Leitor
participant "App\n(Mobile)" as App
participant "ClubeController" as CC
participant "MembroController" as MC
participant "ClubeService" as CS
participant "MembroService" as MS
participant "ClubeRepository" as CR
participant "MembroRepository" as MR
participant "NotificacaoService" as NS
database "PostgreSQL" as DB

== Buscar e Ingressar em Clube ==

Leitor -> App : Busca clubes públicos
activate App

App -> CC : GET /clubes?pagina={n}
activate CC

CC -> CS : listarClubesPublicos(pagina)
activate CS

CS -> CR : findPublicos(pagina)
activate CR
CR -> DB : SELECT clubes WHERE status = ATIVO\nAND privacidade = PUBLICO
activate DB
DB --> CR : Lista de Clubes
deactivate DB
CR --> CS : List<Clube>
deactivate CR

CS --> CC : List<Clube>
deactivate CS

CC --> App : 200 OK {clubes}
deactivate CC

App --> Leitor : Exibe lista de clubes
deactivate App

Leitor -> App : Seleciona clube e solicita entrada
activate App

App -> MC : POST /clubes/{clubeId}/membros\n{usuarioId, codigoAcesso?}
activate MC

MC -> MS : entrarNoClube(clubeId, usuarioId, codigoAcesso)
activate MS

MS -> CR : findById(clubeId)
activate CR
CR -> DB : SELECT clube WHERE id = clubeId
activate DB
DB --> CR : Clube
deactivate DB
CR --> MS : Clube
deactivate CR

MS -> MR : existsByUsuarioIdEClubeId(usuarioId, clubeId)
activate MR
MR -> DB : SELECT EXISTS membro
activate DB
DB --> MR : Boolean
deactivate DB
MR --> MS : false
deactivate MR

MS -> MR : countByClubeId(clubeId)
activate MR
MR -> DB : SELECT COUNT membros
activate DB
DB --> MR : Integer
deactivate DB
MR --> MS : totalAtual
deactivate MR

alt [privacidade == PRIVADO]
  note over MS : validarAcessoPrivado:\nconfere codigoAcesso
end

alt [vagas disponíveis e acesso válido]

  MS -> MR : save(membro: MembroClube\n{papel: MEMBRO})
  activate MR
  MR -> DB : INSERT INTO membros_clube
  activate DB
  DB --> MR : MembroClube persistido
  deactivate DB
  MR --> MS : MembroClube
  deactivate MR

  MS -> NS : enviarNotificacao(adminId,\nNOVO_MEMBRO, payload)
  activate NS
  NS --> MS : ok
  deactivate NS

  MS --> MC : MembroClube
  deactivate MS

  MC --> App : 201 Created {membro}
  deactivate MC

  App --> Leitor : Exibe painel do clube
  deactivate App

else [clube lotado ou código inválido]

  MS --> MC : Erro de validação
  deactivate MS

  MC --> App : 422 Unprocessable Entity
  deactivate MC

  App --> Leitor : Exibe mensagem de erro
  deactivate App

end

@enduml
